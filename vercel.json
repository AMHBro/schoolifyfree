{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://sms-backend-production-eedb.up.railway.app/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://sms-backend-production-eedb.up.railway.app/auth/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
