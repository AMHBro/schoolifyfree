{
  "name": "backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch index.ts",
    "start": "bun index.ts",
    "start:migrate": "bunx prisma migrate deploy && bun index.ts",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev",
    "db:seed": "bun --env-file=.env run prisma/seed.ts",
    "db:studio": "bunx prisma studio",
    "db:fix-migration": "bun fix-failed-migration.ts",
    "db:fix-null-phone": "bun fix-null-contact-phone.ts",
    "db:reset-migrations": "bun reset-migrations.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.3",
    "@elysiajs/jwt": "^1.3.1",
    "@elysiajs/swagger": "^1.3.0",
    "@prisma/client": "^6.9.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/puppeteer": "^7.0.4",
    "@types/ws": "^8.18.1",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.2",
    "elysia": "^1.3.4",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.9.0",
    "puppeteer": "^24.10.0",
    "ws": "^8.18.2"
  },
  "prisma": {
    "seed": "bun --env-file=.env run prisma/seed.ts"
  }
}
